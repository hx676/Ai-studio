                      <TextBlock Text="系统日志目录" FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="data/service-logs" Foreground="{StaticResource TextMute}" FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" ToolTip="data/service-logs"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource TextMute}" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
                
                <!-- 6. 数字人素材输出卡片 / HeyGem videos output dir card -->
                <Button Style="{StaticResource FolderButton}" Click="OpenHeyGemOutputDirClicked">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="40"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="👤" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="数字人素材输出" FontSize="13.5" FontWeight="SemiBold"/>
                      <TextBlock Text="HeyGem 视频结果" Foreground="{StaticResource TextMute}" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="›" FontSize="18" Foreground="{StaticResource TextMute}" VerticalAlignment="Center"/>
                  </Grid>
                </Button>
              </UniformGrid>
