            <!-- 首页右下侧：系统公告面板与一键操作按钮 / Announcement panel & action button -->
            <Grid Grid.Row="1" Grid.Column="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              
              <!-- 标题修改为系统公告 / Title renamed to System Announcement -->
              <TextBlock Text="系统公告" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
              
              <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="启动提醒" FontSize="13" FontWeight="Bold" Foreground="#818CF8" Margin="0,0,0,6"/>
                    <TextBlock Text="点击下方【一键启动】后，启动器会依次拉起主应用、TTS 和 HeyGem。后台预热通常需要一点时间，期间可以切到【控制台】查看实时日志。" TextWrapping="Wrap" LineHeight="18" FontSize="12" Foreground="{StaticResource TextMute}"/>

                    <TextBlock Text="创作入口" FontSize="13" FontWeight="Bold" Foreground="#F59E0B" Margin="0,16,0,6"/>
                    <TextBlock Text="服务就绪后，点击顶部【打开主应用】进入浏览器开始创作。TTS 和 HeyGem 页面默认不自动弹出，保持后台运行即可。" TextWrapping="Wrap" Foreground="#F3F4F6" LineHeight="18" FontSize="12"/>

                    <TextBlock Text="异常处理" FontSize="13" FontWeight="Bold" Foreground="#10B981" Margin="0,16,0,6"/>
                    <TextBlock Text="如果状态长时间停在启动中或部分就绪，先看【控制台】输出；需要定位端口、路径、CUDA 等问题时，再进入【疑难解答】查看建议。" TextWrapping="Wrap" Foreground="{StaticResource TextMute}" LineHeight="18" FontSize="12"/>
                  </StackPanel>
                </ScrollViewer>
              </Border>
              
              <!-- 首页的核心操作按钮（只保留一键启动，启动后动态切换为一键停止） -->
              <StackPanel Grid.Row="2" Margin="0,20,0,0">
                <Button x:Name="HomePrimaryButton" Content="▶  一键启动" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Height="42" FontSize="14.5" Click="StartAllClicked"/>
              </StackPanel>
            </Grid>
          </Grid>

          <!-- 4. 疑难解答页面 / ChecksPage View (优化问题卡片排版) -->
          <Grid x:Name="ChecksPage" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Margin="0,0,0,14">
              <TextBlock Text="疑难解答与服务检查" FontSize="20" FontWeight="Bold"/>
              <TextBlock Text="这里汇总了需要您介入处理的服务异常状态。如需查看底层运行细节，可导出完整日志。" Foreground="{StaticResource TextMute}" Margin="0,6,0,0" FontSize="13"/>
            </StackPanel>
            
            <Border Grid.Row="1" Style="{StaticResource DarkCard}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock x:Name="TroubleSummaryText" Text="尚未诊断" FontSize="16" FontWeight="Bold" Foreground="White"/>
                  <TextBlock x:Name="TroubleHintText" Text="服务未启动时可以先一键启动；需要排查时再手动重新诊断。" Foreground="{StaticResource TextMute}" Margin="0,6,0,0" FontSize="12.5"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                  <Button x:Name="ChecksStartButton" Content="▶ 一键启动" Style="{StaticResource PrimaryButton}" Click="StartAllClicked" Margin="0,0,6,0"/>
                  <Button Content="⟳ 重新诊断" Style="{StaticResource PlainButton}" Click="RefreshClicked" Margin="0,0,6,0"/>
                  <Button Content="▩ 控制台" Style="{StaticResource PlainButton}" Click="NavigateLogs" Margin="0,0,6,0"/>
                  <Button Content="💾 导出完整日志" Style="{StaticResource PlainButton}" Click="ExportLogsClicked"/>
                </WrapPanel>
              </Grid>
            </Border>
            
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
              <StackPanel x:Name="TroubleList"/> <!-- 动态生成的问题警告卡片区 -->
            </ScrollViewer>
          </Grid>

          <!-- 5. 设置页面 / ConfigPage View (多卡片式参数分块设计) -->
          <Grid x:Name="ConfigPage" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="0,0,4,0">
                <TextBlock Text="参数配置中心" FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>

                <!-- 分组 1：主应用配置 -->
                <Border Style="{StaticResource DarkCard}">
                  <StackPanel>
                    <TextBlock Text="主应用设置 (Main Web App)" FontSize="14.5" FontWeight="Bold" Foreground="#818CF8" Margin="0,0,0,12"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      
                      <TextBlock Grid.Row="0" Text="主应用地址" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="0" Grid.Column="1" x:Name="MainBaseUrlBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="1" Text="主应用 Python" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="1" Grid.Column="1" x:Name="MainPythonBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="2" Text="主应用脚本" VerticalAlignment="Center" Margin="0,0,12,4" FontSize="13"/>
                      <TextBox Grid.Row="2" Grid.Column="1" x:Name="MainScriptBox" Margin="0,0,0,4"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- 分组 2：TTS 语音服务配置 -->
                <Border Style="{StaticResource DarkCard}">
                  <StackPanel>
                    <TextBlock Text="语音服务设置 (TTS Engine)" FontSize="14.5" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,12"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      
                      <TextBlock Grid.Row="0" Text="TTS 接口地址" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="0" Grid.Column="1" x:Name="TtsBaseUrlBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="1" Text="TTS 工作根目录" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="1" Grid.Column="1" x:Name="TtsRootBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="2" Text="TTS Python 环境" VerticalAlignment="Center" Margin="0,0,12,4" FontSize="13"/>
                      <TextBox Grid.Row="2" Grid.Column="1" x:Name="TtsPythonBox" Margin="0,0,0,4"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- 分组 3：数字人 HeyGem 服务配置 -->
                <Border Style="{StaticResource DarkCard}">
                  <StackPanel>
                    <TextBlock Text="数字人配置 (HeyGem Live)" FontSize="14.5" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,12"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      
                      <TextBlock Grid.Row="0" Text="HeyGem Gradio 地址" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="0" Grid.Column="1" x:Name="HeyGemBaseUrlBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="1" Text="HeyGem API 端口" VerticalAlignment="Center" Margin="0,0,12,12" FontSize="13"/>
                      <TextBox Grid.Row="1" Grid.Column="1" x:Name="HeyGemApiUrlBox" Margin="0,0,0,12"/>
                      
                      <TextBlock Grid.Row="2" Text="HeyGem 工作根目录" VerticalAlignment="Center" Margin="0,0,12,4" FontSize="13"/>
                      <TextBox Grid.Row="2" Grid.Column="1" x:Name="HeyGemRootBox" Margin="0,0,0,4"/>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- 分组 4：启动器全局偏好 -->
                <Border Style="{StaticResource DarkCard}">
                  <StackPanel>
                    <TextBlock Text="偏好与自动化配置" FontSize="14.5" FontWeight="Bold" Foreground="#EC4899" Margin="0,0,0,12"/>
                    <CheckBox x:Name="OpenMainAfterReadyBox" Content="服务全部就绪后，自动在浏览器中打开主应用界面" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,0,0,4"/>
                  </StackPanel>
                </Border>

                <!-- 配置项保存与撤销操作 -->
                <StackPanel Margin="0,4,0,24">
                  <StackPanel Orientation="Horizontal">
                    <Button Content="💾 保存配置" Style="{StaticResource PrimaryButton}" Click="SaveConfigClicked" Height="36" MinWidth="110"/>
                    <Button Content="⟳ 撤销重载" Style="{StaticResource PlainButton}" Click="ReloadConfigClicked" Height="36" MinWidth="110"/>
                  </StackPanel>
                  <TextBlock x:Name="ConfigStatusText" Text="" Foreground="{StaticResource TextMute}" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Grid>

          <!-- 6. 控制台日志页面 / LogsPage View (优化服务卡片与终端输出) -->
          <Grid x:Name="LogsPage" Visibility="Collapsed">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/> <!-- 控制指令栏 -->
              <RowDefinition Height="Auto"/> <!-- 进程卡片监控区 -->
              <RowDefinition Height="*"/>    <!-- 合并日志终端 -->
            </Grid.RowDefinitions>
            
            <!-- 控制台操作工具条 (重构为通透悬浮风格，适配 Segoe 精致矢量图标按钮与 Toggle Switch) / Transparent modern console toolbar -->
            <Border Background="Transparent" BorderThickness="0" Padding="0,4,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="系统日志聚合控制台" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="#F3F4F6"/>
                
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                  <!-- 使用精致矢量 Path 图标的按钮，平缓微光 hover，100% 兼容无字体的环境 / Native Vector Path buttons -->
                  <Button Content="刷新日志" Style="{StaticResource ConsoleActionButton}" Tag="M 1,5 A 4,4 0 1,1 2,8 M 2,5 L 0,7 M 2,5 L 4,7" Click="ReadLogClicked"/>
                  <Button Content="导出日志" Style="{StaticResource ConsoleActionButton}" Tag="M 2,2 L 8,2 L 10,4 L 10,10 L 2,10 Z M 4,2 L 4,5 L 8,5 L 8,2 M 4,10 L 4,7 L 8,7 L 8,10" Click="ExportLogsClicked"/>
                  <Button Content="日志目录" Style="{StaticResource ConsoleActionButton}" Tag="M 1.5,2 L 4.5,2 L 6,3.5 L 10.5,3.5 L 10.5,10 L 1.5,10 Z M 1.5,3.5 L 10.5,3.5" Click="OpenLogsDirClicked"/>
                  <Button Content="清空屏幕" Style="{StaticResource ConsoleDangerActionButton}" Tag="M 2,3 L 10,3 M 3,3 L 3,10 A 1,1 0 0,0 4,11 L 8,11 A 1,1 0 0,0 9,10 L 9,3 M 5,1 L 7,1 M 5,5 L 5,9 M 7,5 L 7,9" Click="ClearConsoleClicked"/>
                </WrapPanel>
              </Grid>
            </Border>
            
            <!-- 各子服务即时进程状态卡片放置区 -->
            <UniformGrid x:Name="ConsoleServiceCards" Grid.Row="1" Columns="3" Margin="0,0,0,12"/>
            
            <!-- 集成 RichTextBox Terminal -->
            <Border Grid.Row="2" Background="#070709" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="30"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Terminal 头部 -->
                <Border Grid.Row="0" Background="#12131A" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="🗲 Terminal" FontSize="11" Foreground="#6366F1" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="·" FontSize="14" Foreground="#4B5563" Margin="8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="子服务合并 stdout/stderr 日志流 (自动隐藏心跳检测)" FontSize="11" Foreground="{StaticResource TextMute}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
                
                <!-- 日志文本输出 -->
                <RichTextBox x:Name="ConsoleTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Cascadia Code, Courier New"
                             FontSize="12"
                             Foreground="#D1D5DB"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10"
                             Padding="6"/>
              </Grid>
            </Border>
          </Grid>
        </Grid>

        <!-- 底部全局状态页脚 / Styled Windows Status Footer -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
          <Border BorderBrush="#1D1E2A" BorderThickness="0,1,0,0" Margin="0,8,0,8"/>
          <Grid>
            <TextBlock Text="SynCanvas System Launcher v1.0.0" Foreground="#3E4256" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
