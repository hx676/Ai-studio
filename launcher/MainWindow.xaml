<Window x:Class="SynCanvasLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SynCanvas 启动器"
        Width="1280"
        Height="800"
        MinWidth="1060"
        MinHeight="680"
        Background="#0B0B0E"
        Icon="app.ico"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, Arial"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"> <!-- 设置窗口左上角及任务栏图标 / Set window icon to app.ico -->
  <!-- 启用 WindowChrome 自定义现代化无边框标题栏，并保留标准的调整大小、拖拽移动以及贴靠等系统窗口行为 / Custom WindowChrome -->
  <WindowChrome.WindowChrome>
    <WindowChrome GlassFrameThickness="0" 
                  CornerRadius="0" 
                  CaptionHeight="52" 
                  ResizeBorderThickness="6" />
  </WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- 全局调色板定义 / Visual Design Palette Tokens -->
    <SolidColorBrush x:Key="AppBg" Color="#0B0B0E"/> <!-- 主窗口背景色 -->
    <SolidColorBrush x:Key="PanelBg" Color="#15161E"/> <!-- 卡片与面板的背景色 -->
    <SolidColorBrush x:Key="PanelBgSoft" Color="#1E1F2A"/> <!-- 卡片或按钮悬停状态的背景色 -->
    <SolidColorBrush x:Key="PanelBorder" Color="#272938"/> <!-- 控件边框颜色 -->
    <SolidColorBrush x:Key="TextMain" Color="#F3F4F6"/> <!-- 主文本颜色 (高对比度) -->
    <SolidColorBrush x:Key="TextMute" Color="#8E9CAE"/> <!-- 副/静音文本颜色 -->
    <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/> <!-- 品牌科技蓝 -->
    <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/> <!-- 品牌警告红 -->

    <!-- 品牌渐变色画刷定义 / Premium Gradients -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#4F46E5" Offset="0"/>
      <GradientStop Color="#7C3AED" Offset="1"/>
    </LinearGradientBrush> <!-- 主渐变：靛蓝到紫罗兰 -->

    <LinearGradientBrush x:Key="HoverGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#6366F1" Offset="0"/>
      <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush> <!-- 主渐变悬停亮化效果 -->

    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#E11D48" Offset="0"/>
      <GradientStop Color="#F43F5E" Offset="1"/>
    </LinearGradientBrush> <!-- 危险渐变：胭脂红到玫瑰红 -->

    <LinearGradientBrush x:Key="DangerHoverGradient" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#FB7185" Offset="0"/>
      <GradientStop Color="#FF0055" Offset="1"/>
    </LinearGradientBrush> <!-- 危险渐变悬停亮化效果 -->

    <!-- 半透明磨砂玻璃卡片背景 / Glassmorphism Backgrounds -->
    <SolidColorBrush x:Key="GlassBg" Color="#141520" Opacity="0.7"/>
    <SolidColorBrush x:Key="GlassBorder" Color="#2E3048" Opacity="0.8"/>

    <!-- 全局文本样式 / Global TextBlock Style -->
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, Arial"/>
      <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
      <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
      <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
    </Style>

    <!-- 输入框模板与样式优化 / Styled TextBox -->
    <Style TargetType="TextBox">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Background" Value="#0F1015"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CaretBrush" Value="{StaticResource TextMain}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
              <ScrollViewer x:Name="PART_ContentHost" Margin="2,0,2,0" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="true">
                <Setter TargetName="border" Property="BorderBrush" Value="#4B5563"/>
              </Trigger>
              <Trigger Property="IsFocused" Value="true">
                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                <Setter TargetName="border" Property="Background" Value="#13141D"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 下拉选择框样式 / Styled ComboBox -->
    <Style TargetType="ComboBox">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Background" Value="#15161E"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
    </Style>

    <!-- 侧边导航按钮样式 / NavButton Style -->
    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Height" Value="66"/>
      <Setter Property="Margin" Value="6,3,6,3"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#171822"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 主操作渐变按钮 / Primary Gradient Button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Height" Value="40"/>
      <Setter Property="MinWidth" Value="120"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="Padding" Value="18,0"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{StaticResource PrimaryGradient}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverGradient}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#3730A3"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                <Setter Property="Foreground" Value="#9CA3AF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 次要普通按钮 / Plain Style Button -->
    <Style x:Key="PlainButton" TargetType="Button">
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="82"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="#1D1E28" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Value="#292A38" Property="Background"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#4B5563"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Value="#171820" Property="Background"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Value="#101116" Property="Background"/>
                <Setter Property="Foreground" Value="#4B5563"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 危险操作按钮 / Danger Red Button -->
    <Style x:Key="DangerButton" TargetType="Button">
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="82"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <!-- 采用与主按钮一致的渐变无边框圆角设计，极大提升高级感 / Rounded gradient border -->
            <Border x:Name="border" Background="{StaticResource DangerGradient}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <!-- 悬停亮化 / Hover animation -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerHoverGradient}"/>
              </Trigger>
              <!-- 按下深色反馈 / Pressed animation -->
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#9F1239"/>
              </Trigger>
              <!-- 禁用状态置灰 / Disabled style -->
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Background" Value="#374151"/>
                <Setter Property="Foreground" Value="#9CA3AF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 高级面板卡片样式 / Styled Card Panel -->
    <Style x:Key="DarkCard" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- 文件夹快捷方式玻璃按钮样式 / Folder Card Style -->
    <Style x:Key="FolderButton" TargetType="Button">
      <Setter Property="MinHeight" Value="78"/>
      <Setter Property="Margin" Value="0,0,12,12"/>
      <Setter Property="Padding" Value="16,12"/> <!-- 增加上下内边距使得比例更加和谐，防止文字贴边 / Set balanced padding -->
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Background" Value="{StaticResource GlassBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource GlassBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <!-- 绑定 Padding 到 Border，使其内容 Grid 自动与外框产生安全内边距 / Bind Padding to Border for safe margins -->
            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
              <!-- 设置 VerticalAlignment=Center 保证容器内多列元素垂直居中对齐 / Vertically center the content -->
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#1D1E2C"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#494D74"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#151622"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 窗口标题栏控制按钮样式 / Custom Window Chrome Control Buttons -->
    <Style x:Key="ChromeButton" TargetType="Button">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="52"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <!-- 标记为非客户区内可点击测试可见，否则会被 WindowChrome 拖动拦截 / Enable HitTest for WindowChrome -->
      <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <!-- 悬停时采用浅白透明高亮，增强现代质感 / White transparent hover -->
                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 关闭按钮专用红色高亮样式 / Chrome Close Button Red Hover Style -->
    <Style x:Key="ChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <!-- 悬停时变为标准 Windows 关闭红 / Windows standard close red -->
                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#F1707A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 极简现代深色滚动条样式 / Modern Dark Minimal ScrollBar Style -->
    <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <!-- 滑块主体：圆角矩形，平时呈半透明暗灰，悬停及拖拽时高亮 / Thumb Border style -->
            <Border x:Name="chrome" 
                    Background="#2E3045" 
                    CornerRadius="3" 
                    Margin="2,0,2,0"/>
            <ControlTemplate.Triggers>
              <!-- 悬停亮化 / Hover highlight -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="chrome" Property="Background" Value="#4B4F70"/>
              </Trigger>
              <!-- 拖拽高亮 / Dragging state highlight -->
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="chrome" Property="Background" Value="#6366F1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 隐式滚动条样式，自动应用到窗口内所有滚动容器中 / Implicit ScrollBar Style -->
    <Style TargetType="ScrollBar">
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Style.Triggers>
        <!-- 垂直滚动条 / Vertical ScrollBar template -->
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="8"/>
          <Setter Property="Height" Value="Auto"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                  <!-- 垂直滑块轨道，去掉上下箭头按钮，只保留滑块本体 / Track containing custom thumb -->
                  <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                    </Track.Thumb>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
        <!-- 水平滚动条 / Horizontal ScrollBar template -->
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Width" Value="Auto"/>
          <Setter Property="Height" Value="8"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                  <!-- 水平滑块轨道 / Track containing custom horizontal thumb -->
                  <Track x:Name="PART_Track" IsEnabled="{TemplateBinding IsEnabled}">
                    <Track.DecreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="false"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                      <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="false"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                      <Thumb Style="{StaticResource ModernScrollBarThumb}">
                        <Thumb.Template>
                          <ControlTemplate TargetType="Thumb">
                            <Border x:Name="chrome" 
                                    Background="#2E3045" 
                                    CornerRadius="3" 
                                    Margin="0,2,0,2"/>
                            <ControlTemplate.Triggers>
                              <!-- 悬停亮化 / Hover highlight -->
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chrome" Property="Background" Value="#4B4F70"/>
                              </Trigger>
                              <!-- 拖拽高亮 / Dragging state highlight -->
                              <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="chrome" Property="Background" Value="#6366F1"/>
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Thumb.Template>
                      </Thumb>
                    </Track.Thumb>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- 隐式滚动容器样式，强制内部的所有滚动条显式加载自定义模板 / Implicit ScrollViewer Style to force custom scrollbars -->
    <Style TargetType="ScrollViewer">
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollViewer">
            <Grid x:Name="Grid" Background="{TemplateBinding Background}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <!-- 文本或内容显示主视区 / Main scroll content presenter -->
              <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" 
                                      CanContentScroll="{TemplateBinding CanContentScroll}" 
                                      CanHorizontallyScroll="False" 
                                      CanVerticallyScroll="False" 
                                      ContentTemplate="{TemplateBinding ContentTemplate}" 
                                      Content="{TemplateBinding Content}" 
                                      Grid.Column="0" 
                                      Margin="{TemplateBinding Padding}" 
                                      Grid.Row="0"/>
              <!-- 自定义垂直滚动条 / Custom vertical scrollbar -->
              <ScrollBar x:Name="PART_VerticalScrollBar" 
                         AutomationProperties.AutomationId="VerticalScrollBar" 
                         Cursor="Arrow" 
                         Grid.Column="1" 
                         Maximum="{TemplateBinding ScrollableHeight}" 
                         Minimum="0" 
                         Grid.Row="0" 
                         Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" 
                         Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                         ViewportSize="{TemplateBinding ViewportHeight}" 
                         Width="8"/>
              <!-- 自定义水平滚动条 / Custom horizontal scrollbar -->
              <ScrollBar x:Name="PART_HorizontalScrollBar" 
                         AutomationProperties.AutomationId="HorizontalScrollBar" 
                         Cursor="Arrow" 
                         Grid.Column="0" 
                         Maximum="{TemplateBinding ScrollableWidth}" 
                         Minimum="0" 
                         Orientation="Horizontal" 
                         Grid.Row="1" 
                         Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" 
                         Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" 
                         ViewportSize="{TemplateBinding ViewportWidth}" 
                         Height="8"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 极简现代深色 CheckBox 样式 / Modern Dark CheckBox Style -->
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <!-- 整体容器采用 Grid 布局，便于对齐 / Checkbox container Grid -->
            <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              
              <!-- 1. 自定义选择框框体 / Custom checkbox outer border -->
              <Border x:Name="checkBoxBorder" 
                      Grid.Column="0"
                      Width="15" 
                      Height="15" 
                      Background="#0F1015" 
                      BorderBrush="{StaticResource PanelBorder}" 
                      BorderThickness="1" 
                      CornerRadius="3" 
                      VerticalAlignment="Center" 
                      HorizontalAlignment="Left" 
                      Margin="0,0,8,0">
                <!-- 内部对勾容器 / Inner checkmark block -->
                <Grid x:Name="markGrid">
                  <!-- 现代极简扁平化小对勾 / Flat modern checkmark path -->
                  <Path x:Name="optionMark" 
                        Data="M 2.5,7 L 5.5,10 L 11.5,3.5" 
                        Stroke="White" 
                        StrokeThickness="1.8" 
                        StrokeStartLineCap="Round" 
                        StrokeEndLineCap="Round" 
                        Visibility="Collapsed"/>
                </Grid>
              </Border>
              
              <!-- 2. 内容呈现区 / Label ContentPresenter -->
              <ContentPresenter Grid.Column="1" 
                                x:Name="contentPresenter" 
                                Focusable="False" 
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                Margin="{TemplateBinding Padding}" 
                                RecognizesAccessKey="True" 
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
              <!-- 鼠标悬停，选择框框体边框亮化 / Hover state -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#4B5563"/>
                <Setter TargetName="checkBoxBorder" Property="Background" Value="#171822"/>
              </Trigger>
              <!-- 选中状态，选择框框体填充为主渐变色，对勾显示 / Checked state -->
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="checkBoxBorder" Property="Background" Value="#6366F1"/>
                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#6366F1"/>
                <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>
              </Trigger>
              <!-- 禁用状态置灰 / Disabled state -->
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="checkBoxBorder" Property="Background" Value="#1F2937"/>
                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#374151"/>
                <Setter TargetName="optionMark" Property="Stroke" Value="#9CA3AF"/>
                <Setter Property="Foreground" Value="#6B7280"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 科技感滑动开关样式 (Toggle Switch) / Custom premium Toggle Switch CheckBox Style -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <!-- 使用 StackPanel 保持图标与文字的紧凑水平排列 / Horizontal alignment -->
            <StackPanel Orientation="Horizontal" Background="Transparent">
              <!-- 滑动轨道与滑块的容器 Grid / Track container -->
              <Grid x:Name="grid" Width="38" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                <!-- 轨道背景 / Slide Track -->
                <Border x:Name="background" Background="#1D1E28" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10"/>
                <!-- 滑块圆点 / Thumb -->
                <Border x:Name="thumb" Width="12" Height="12" Background="#8E9CAE" CornerRadius="6" HorizontalAlignment="Left" Margin="4,0,4,0" VerticalAlignment="Center">
                  <Border.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                  </Border.RenderTransform>
                </Border>
              </Grid>
              <!-- 文字内容 / Content presenter -->
              <ContentPresenter x:Name="contentPresenter" VerticalAlignment="Center" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </StackPanel>
            <ControlTemplate.Triggers>
              <!-- 悬停状态：边框微亮 -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="background" Property="BorderBrush" Value="#4B5563"/>
                <Setter TargetName="background" Property="Background" Value="#222331"/>
              </Trigger>
              <!-- 选中状态：轨道填充科技蓝，滑块滑至右侧，并呈现白色 / Checked slide animation -->
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="background" Property="Background" Value="{StaticResource PrimaryGradient}"/>
                <Setter TargetName="background" Property="BorderBrush" Value="#6366F1"/>
                <Setter TargetName="thumb" Property="Background" Value="White"/>
                <!-- 开启滑块移动动画 / Translation animation -->
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="thumb" 
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                       To="18" 
                                       Duration="0:0:0.12"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <!-- 关闭滑块移动动画 -->
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="thumb" 
                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                       To="0" 
                                       Duration="0:0:0.12"/>
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
              </Trigger>
              <!-- 禁用状态 -->
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="background" Property="Background" Value="#0F1015"/>
                <Setter TargetName="thumb" Property="Background" Value="#3E4256"/>
                <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 控制台专用扁平带图标按钮 / Premium flat button with vector Path icon -->
    <Style x:Key="ConsoleActionButton" TargetType="Button">
      <Setter Property="Height" Value="30"/>
      <Setter Property="MinWidth" Value="88"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <!-- 采用精致细致的微边框暗色背景，极具质感 / Thin border style -->
            <Border x:Name="border" Background="#141520" BorderBrush="#242637" BorderThickness="1" CornerRadius="6">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 矢量图标 Path：绑定至 Tag，使用 RenderTransform 顺滑对齐，100% 跨平台兼容 / Native Vector Path -->
                <Path x:Name="path" 
                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" 
                      StrokeThickness="1.2" 
                      StrokeStartLineCap="Round" 
                      StrokeEndLineCap="Round" 
                      Width="12" 
                      Height="12" 
                      Stretch="Uniform" 
                      VerticalAlignment="Center" 
                      Margin="0,0,6,0"/>
                <!-- 按钮文字内容 / Content -->
                <ContentPresenter x:Name="content" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <!-- 悬停时：背景呈现深蓝科技感，边框变为科技蓝，文本与图标高亮 / Hover highlight -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#1E2235"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <!-- 按下时：缩进和深色反馈 / Pressed feedback -->
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#121422"/>
              </Trigger>
              <!-- 禁用时：整体灰度化 / Disabled style -->
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Background" Value="#0F1015"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#1C1D26"/>
                <Setter Property="Foreground" Value="#3E4256"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 控制台专用危险操作按钮 (主要用于清空屏幕，带有柔和红色悬停反馈) / Console danger flat button -->
    <Style x:Key="ConsoleDangerActionButton" TargetType="Button">
      <Setter Property="Height" Value="30"/>
      <Setter Property="MinWidth" Value="88"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="#141520" BorderBrush="#242637" BorderThickness="1" CornerRadius="6">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path x:Name="path" 
                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" 
                      StrokeThickness="1.2" 
                      StrokeStartLineCap="Round" 
                      StrokeEndLineCap="Round" 
                      Width="12" 
                      Height="12" 
                      Stretch="Uniform" 
                      VerticalAlignment="Center" 
                      Margin="0,0,6,0"/>
                <ContentPresenter x:Name="content" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <!-- 悬停时：背景呈现暗玫瑰红，边框变为警告红，文本与图标高亮为浅粉 / Hover danger highlight -->
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#25161C"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#E11D48"/>
                <Setter Property="Foreground" Value="#FB7185"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#1A0E13"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Background" Value="#0F1015"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#1C1D26"/>
                <Setter Property="Foreground" Value="#3E4256"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid x:Name="MainGrid" Background="{StaticResource AppBg}">
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/> <!-- 顶栏高度调整为 52，显得更加舒适 -->
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 顶栏状态与控制区域 / Top Control Header Bar -->
    <Border Grid.Row="0" Background="#11121A" BorderBrush="#1D1E2A" BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/> <!-- 用于存放刷新、状态、打开主应用等 -->
          <ColumnDefinition Width="Auto"/> <!-- 用于存放自定义窗口三件套按钮 -->
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：品牌信息与根目录路径，已根据要求剔除图标与“启动器”字样，仅保留 SynCanvas /Draggable title -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
          <TextBlock Text="SynCanvas" FontSize="15.5" FontWeight="Bold" VerticalAlignment="Center"/>
          <TextBlock x:Name="MainUrlText" Text="http://127.0.0.1:3000/" Foreground="#6366F1" Margin="20,1,0,0" FontSize="13" VerticalAlignment="Center" Visibility="Collapsed"/>
          <TextBlock x:Name="RootPathText" Text="加载中..." Foreground="#525B70" Margin="20,1,0,0" FontSize="12.5" VerticalAlignment="Center" Visibility="Collapsed"/>
        </StackPanel>
        
        <!-- 右侧：全局服务状态指示器与基本功能键，设置为 Collapsed 隐藏以保持顶栏清爽，同时在后台保留引用防止编译报错 / Hidden to keep titlebar clean -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0" WindowChrome.IsHitTestVisibleInChrome="True" Visibility="Collapsed">
          <TextBlock x:Name="TopStatusText" Text="正在读取状态" Foreground="{StaticResource TextMute}" Margin="0,0,20,0" FontSize="13" VerticalAlignment="Center"/>
          <Button Content="⟳ 刷新" Style="{StaticResource PlainButton}" Click="RefreshClicked" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <Button Content="🌐 打开主应用" Style="{StaticResource PlainButton}" Click="OpenMainClicked" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 最右侧：自定义窗口控制三件套按钮，贴边放置，且标记为 WindowChrome 中点击可见 / Window chrome buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" WindowChrome.IsHitTestVisibleInChrome="True">
          <Button Content="—" Style="{StaticResource ChromeButton}" Click="MinimizeWindowClicked" ToolTip="最小化"/>
          <Button x:Name="MaximizeButton" Content="☐" Style="{StaticResource ChromeButton}" Click="MaximizeWindowClicked" ToolTip="最大化"/>
          <Button Content="✕" Style="{StaticResource ChromeCloseButton}" Click="CloseWindowClicked" ToolTip="关闭"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 主窗口工作区，采用左导航、右内容的分栏设计 -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="80"/> <!-- 侧边栏宽度 80 -->
        <ColumnDefinition Width="*"/>  <!-- 内容区域自适应 -->
      </Grid.ColumnDefinitions>

      <!-- 侧边导航栏 / Sidebar Navigation Panel -->
      <Border Grid.Column="0" Background="#11121A" BorderBrush="#1D1E2A" BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
            <!-- 首页导航项 (优化添加) -->
            <Button x:Name="HomeNav" Style="{StaticResource NavButton}" Click="NavigateHome">
              <StackPanel>
                <TextBlock Text="🏠" FontSize="20" HorizontalAlignment="Center"/>
                <TextBlock Text="首页" FontSize="11" HorizontalAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Button>

            
            <!-- 高级选项导航项 -->
            <Button x:Name="AdvancedNav" Style="{StaticResource NavButton}" Click="NavigateConfig">
              <StackPanel>
                <TextBlock Text="☷" FontSize="20" HorizontalAlignment="Center"/>
                <TextBlock Text="高级选项" FontSize="11" HorizontalAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Button>
            
            <!-- 疑难解答导航项 -->
            <Button x:Name="CheckNav" Style="{StaticResource NavButton}" Click="NavigateChecks">
              <StackPanel>
                <TextBlock Text="⚒" FontSize="19" HorizontalAlignment="Center"/>
                <TextBlock Text="疑难解答" FontSize="11" HorizontalAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Button>
            
          </StackPanel>
          
          <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
            <!-- 控制台导航项 -->
            <Button x:Name="LogsNav" Style="{StaticResource NavButton}" Click="NavigateLogs">
              <StackPanel>
                <TextBlock Text="▰" FontSize="18" HorizontalAlignment="Center"/>
                <TextBlock Text="控制台" FontSize="11" HorizontalAlignment="Center" Margin="0,7,0,0"/>
              </StackPanel>
            </Button>
            
            <!-- 设置导航项 -->
